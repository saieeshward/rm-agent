# Copy to .env on the VM (this directory) — gitignored. `docker compose` reads it.

# Public HTTPS hostname → must resolve to this VM's public IP.
# Free option: nip.io maps <ip-with-dashes>.nip.io to that IP, e.g.
#   SITE_ADDRESS=203-0-113-5.nip.io
SITE_ADDRESS=

# Model (free, tool-calling capable — same as the rest of the project)
MODEL=openrouter:openai/gpt-oss-120b:free
OPENROUTER_API_KEY=

# Basic auth for the public agent URL (private — never commit the real values)
BASIC_AUTH_USER=gm
BASIC_AUTH_PASS=
