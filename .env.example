# Copy to .env (gitignored) and uncomment ONE provider block, then:
#   . .venv/bin/activate && python -m agent.run "what's driving July?"

# --- Gemini (free tier; key: https://aistudio.google.com/apikey) ---
# MODEL=google_genai:gemini-2.5-flash
# GOOGLE_API_KEY=your-key-here

# --- OpenRouter (one key -> many models; key: https://openrouter.ai/keys) ---
# Free models exist (weaker tool-calling); for quality use a paid model id:
# MODEL=openrouter:anthropic/claude-3.5-sonnet
# OPENROUTER_API_KEY=your-key-here

# --- Anthropic direct (best quality; key: https://console.anthropic.com) ---
# MODEL=anthropic:claude-sonnet-4-6
# ANTHROPIC_API_KEY=your-key-here

# --- Local, no key (proves wiring; small models may loop/mis-format) ---
# MODEL=ollama:mistral-nemo:latest

# Postgres (defaults to the docker-compose DB)
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hotel_hackathon
